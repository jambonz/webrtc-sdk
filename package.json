{
  "name": "jambonz-webrtc-sdk",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:web": "cd packages/web && npx playwright test --config playwright.config.ts",
    "format": "prettier --write \"packages/*/src/**/*.ts\""
  },
  "packageManager": "npm@10.0.0",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "dotenv": "^17.3.1",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0",
    "typescript": "^5.4.0"
  }
}
