# Jambonz WebRTC SDK — Integration Test Environment Variables
#
# Copy this file to .env.test and fill in your values:
#   cp .env.test.example .env.test
#
# These are used by integration tests that connect to a real Jambonz SBC.

# WebSocket URL of your Jambonz SBC
JAMBONZ_SIP_SERVER=wss://sip.jambonz.me:8443

# SIP credentials for the test account
JAMBONZ_SIP_USERNAME=testuser
JAMBONZ_SIP_PASSWORD=testpassword

# Target number/SIP URI to call during outbound call tests
JAMBONZ_CALL_TARGET=1234567890

# (Optional) A second SIP account for incoming call tests
# If set, the test will register a second client and call it
JAMBONZ_SIP_USERNAME_2=testuser2
JAMBONZ_SIP_PASSWORD_2=testpassword2
